# API подставляется автоматически:
# - Разработка (npm run dev): http://127.0.0.1:8000
# - Продакшен (npm run build): https://api.axione.store
#
# Переопределить прод-хост (.env.production):
# VITE_API_BASE_URL=https://api.axione.store
# VITE_MEDIA_BASE_URL=https://api.axione.store
#
# Слаг сайта для API site_integrations (категории по бизнесу), по умолчанию buildgood:
# VITE_SITE_SLUG=buildgood
